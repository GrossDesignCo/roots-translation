{
  "name": "roots-translation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:data-chapters-as-markdown": "tsx src/data/pipeline/generateScriptureChaptersAsMarkdown.ts",
    "build:data-lexicon-index-by-word": "tsx scripts/build-lexicon-index.ts",
    "build:data-root-indexes": "tsx src/data/pipeline/generateRootIndexes.ts",
    "build:data-root-files": "tsx src/data/pipeline/generateRootFiles.ts",
    "build:data": "npm run build:data-chapters-as-markdown && npm run build:data-lexicon-index-by-word && npm run build:data-root-indexes && npm run build:data-root-files",
    "build:meta-translation-progress": "tsx src/data/pipeline/generateTranslationProgress.ts",
    "build:meta": "npm run build:meta-translation-progress",
    "build:all": "npm run build:data && npm run build:meta && npm run build",
    "start": "next start",
    "lint": "eslint .",
    "test": "jest",
    "prepare": "husky install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^16.0.7",
    "@phosphor-icons/react": "^2.1.7",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-tooltip": "^1.2.4",
    "@types/mdx": "^2.0.13",
    "classnames": "^2.5.1",
    "next": "^16.2.3",
    "next-themes": "^0.4.6",
    "npm-run-all": "^4.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "baseline-browser-mapping": "^2.10.17",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.3",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.1",
    "ts-jest": "^29.1.1",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.jest.json"
        }
      ]
    }
  },
  "lint-staged": {
    "src/data/scripture/**/*.ts": [
      "node --experimental-modules scripts/update-last-reviewed.js"
    ]
  }
}
